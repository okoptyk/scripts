---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Lang from '@/components/Lang.astro';
import MetaBlock from '@/components/MetaBlock.astro';
import MetaItem from '@/components/MetaItem.astro';
import Tabs from '@/components/Tabs.astro';
import TabPanel from '@/components/TabPanel.astro';
import Section from '@/components/Section.astro';
import ScriptLang from '@/components/ScriptLang.astro';
import ScriptLangPanel from '@/components/ScriptLangPanel.astro';
import TemplateBox from '@/components/TemplateBox.astro';
import TipBlock from '@/components/TipBlock.astro';
import Step from '@/components/Step.astro';
import StagePath from '@/components/StagePath.astro';
import { t } from './_i18n';

const slug = 'gotovnost-zakaza';
const LANGS = ['ru','ua','pl'] as const;
---
<BaseLayout slug={slug}>
  <div class="page-header">
    <div class="page-header-inner">
      {LANGS.map((l) => (
        <Lang lang={l}>
          <h1>{t.headerTitle[l]}</h1>
          <p>{t.headerSub[l]}</p>
        </Lang>
      ))}
    </div>
  </div>

  <div class="container">
    <MetaBlock>
      {LANGS.map((l) => (
        <Lang lang={l}>
          <MetaItem label={t.metaCkpLabel[l]} html={t.metaCkp[l]} />
          <MetaItem label={t.metaStartLabel[l]} html={t.metaStart[l]} />
          <MetaItem label={t.metaCrmLabel[l]} html={t.metaCrm[l]} />
          <MetaItem label={t.metaDeadlineLabel[l]} html={t.metaDeadline[l]} />
        </Lang>
      ))}
    </MetaBlock>

    <Tabs buttons={[{ id:'msg', label: t.tabMsg.ru }, { id:'call', label: t.tabCall.ru }]}>
      <TabPanel id="msg" first>
        <Section>
          {LANGS.map((l) => (
            <Lang lang={l}>
              <div class="section-title">{t.sttlMsg[l]}</div>
              <div class="info-box" set:html={t.introMsg[l]} />
            </Lang>
          ))}
          <ScriptLang>
            {LANGS.map((l) => (
              <ScriptLangPanel lang={l}>
                <TemplateBox id={`tmpl-ready-${l}`} copyLabel={t.copyLabel[l]} html={t.tmplReady[l]} />
              </ScriptLangPanel>
            ))}
          </ScriptLang>
        </Section>
        {LANGS.map((l) => (
          <Lang lang={l}><TipBlock html={t.tipMsg[l]} /></Lang>
        ))}
      </TabPanel>

      <TabPanel id="call">
        <Section>
          {LANGS.map((l) => (
            <Lang lang={l}>
              <div class="section-title">{t.sttlCall[l]}</div>
              <div class="steps">
                <Step num={1} title={t.callStep1Title[l]} html={t.callStep1[l]} />
                <Step num={2} title={t.callStep2Title[l]} html={t.callStep2[l]} />
                <Step num={3} title={t.callStep3Title[l]} html={t.callStep3[l]} />
              </div>
            </Lang>
          ))}
        </Section>
        {LANGS.map((l) => (
          <Lang lang={l}><TipBlock html={t.tipCall[l]} /></Lang>
        ))}
      </TabPanel>
    </Tabs>

    {LANGS.map((l) => (
      <Lang lang={l}><StagePath current={slug} lang={l} nextLabel={t.nextBtn[l]} /></Lang>
    ))}
  </div>
</BaseLayout>

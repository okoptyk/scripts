---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Lang from '@/components/Lang.astro';
import MetaBlock from '@/components/MetaBlock.astro';
import MetaItem from '@/components/MetaItem.astro';
import Section from '@/components/Section.astro';
import ScriptLang from '@/components/ScriptLang.astro';
import ScriptLangPanel from '@/components/ScriptLangPanel.astro';
import TemplateBox from '@/components/TemplateBox.astro';
import TipBlock from '@/components/TipBlock.astro';
import StagePath from '@/components/StagePath.astro';
import { t } from './_i18n';

const slug = 'reaktivaciya';
const LANGS = ['ru','ua','pl'] as const;
---
<BaseLayout slug={slug}>
  <div class="page-header">
    <div class="page-header-inner">
      {LANGS.map((l) => (
        <Lang lang={l}>
          <h1>{t.headerTitle[l]}</h1>
          <p>{t.headerSub[l]}</p>
        </Lang>
      ))}
    </div>
  </div>

  <div class="container">
    <MetaBlock>
      {LANGS.map((l) => (
        <Lang lang={l}>
          <MetaItem label={t.metaCkpLabel[l]} html={t.metaCkp[l]} />
          <MetaItem label={t.metaStartLabel[l]} html={t.metaStart[l]} />
          <MetaItem label={t.metaResponsibleLabel[l]} html={t.metaResponsible[l]} />
          <MetaItem label={t.metaChannelsLabel[l]} html={t.metaChannels[l]} />
        </Lang>
      ))}
    </MetaBlock>

    <Section>
      {LANGS.map((l) => (
        <Lang lang={l}>
          <div class="section-title">{t.sttl[l]}</div>
          <div class="info-box" set:html={t.intro[l]} />
        </Lang>
      ))}
      <ScriptLang>
        {LANGS.map((l) => (
          <ScriptLangPanel lang={l} idBase="react">
            <div class="step-header" style="margin:8px 0;"><span class="step-num">1</span> {t.var1Title[l]}</div>
            <TemplateBox id={`react-var1-${l}`} copyLabel={t.copyLabel[l]} html={t.var1[l]} />
            <div class="step-header" style="margin:20px 0 8px;"><span class="step-num">2</span> {t.var2Title[l]}</div>
            <TemplateBox id={`react-var2-${l}`} copyLabel={t.copyLabel[l]} html={t.var2[l]} />
            <div class="step-header" style="margin:20px 0 8px;"><span class="step-num">3</span> {t.var3Title[l]}</div>
            <TemplateBox id={`react-var3-${l}`} copyLabel={t.copyLabel[l]} html={t.var3[l]} />
          </ScriptLangPanel>
        ))}
      </ScriptLang>
    </Section>

    {LANGS.map((l) => (
      <Lang lang={l}><TipBlock html={t.tip[l]} /></Lang>
    ))}

    {LANGS.map((l) => (
      <Lang lang={l}><StagePath current={slug} lang={l} nextLabel={t.nextBtn[l]} /></Lang>
    ))}
  </div>
</BaseLayout>

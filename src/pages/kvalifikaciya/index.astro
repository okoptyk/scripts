---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Lang from '@/components/Lang.astro';
import MetaBlock from '@/components/MetaBlock.astro';
import MetaItem from '@/components/MetaItem.astro';
import Tabs from '@/components/Tabs.astro';
import TabPanel from '@/components/TabPanel.astro';
import InfoBox from '@/components/InfoBox.astro';
import ScriptLang from '@/components/ScriptLang.astro';
import ScriptLangPanel from '@/components/ScriptLangPanel.astro';
import StagePath from '@/components/StagePath.astro';
import { t } from './_i18n';

const slug = 'kvalifikaciya';
const LANGS = ['ru','ua','pl'] as const;
---
<BaseLayout slug={slug} copy=".tab-panel[data-tab='messenger']">
  <div class="page-header">
    <div class="page-header-inner">
      {LANGS.map((l) => (
        <Lang lang={l}>
          <h1>{t.headerTitle[l]}</h1>
          <p>{t.headerSub[l]}</p>
        </Lang>
      ))}
    </div>
  </div>

  <div class="container">
    <MetaBlock>
      {LANGS.map((l) => (
        <Lang lang={l}>
          <MetaItem label={t.metaCkpLabel[l]} html={t.metaCkp[l]} />
          <MetaItem label={t.metaDeadlineLabel[l]} html={t.metaDeadline[l]} />
          <MetaItem label={t.metaResponsibleLabel[l]} html={t.metaResponsible[l]} />
          <MetaItem label={t.metaChannelsLabel[l]} html={t.metaChannels[l]} />
        </Lang>
      ))}
    </MetaBlock>

    <Tabs buttons={[{ id:'messenger', label: t.tabMsg.ru }, { id:'phone', label: t.tabPhone.ru }]}>
      <TabPanel id="messenger" first>
        {LANGS.map((l) => (
          <Lang lang={l}><InfoBox html={t.rules[l]} /></Lang>
        ))}
        <ScriptLang>
          {LANGS.map((l) => (
            <ScriptLangPanel lang={l} idBase="msg">
              <div set:html={t.msgBody[l]} />
            </ScriptLangPanel>
          ))}
        </ScriptLang>
      </TabPanel>

      <TabPanel id="phone">
        <div set:html={t.phoneBody} />
      </TabPanel>
    </Tabs>

    {LANGS.map((l) => (
      <Lang lang={l}><StagePath current={slug} lang={l} nextLabel={t.nextBtn[l]} /></Lang>
    ))}
  </div>
</BaseLayout>

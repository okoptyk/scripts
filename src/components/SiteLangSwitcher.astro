---
// The RU/UA/PL buttons in the navbar. Logic lives in public/scripts/site-lang.js.
---
<div class="navbar-lang" role="group" aria-label="Язык сайта">
  <span class="lang-ic" aria-hidden="true">🌐</span>
  <button type="button" class="site-lang-btn active" data-lang="ru" onclick="setSiteLang('ru')">RU</button>
  <button type="button" class="site-lang-btn" data-lang="ua" onclick="setSiteLang('ua')">UA</button>
  <button type="button" class="site-lang-btn" data-lang="pl" onclick="setSiteLang('pl')">PL</button>
</div>

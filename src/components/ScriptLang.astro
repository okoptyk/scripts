---
// ScriptLang.astro — the .lang-group with RU/UA/PL buttons + panels slot
---
<div class="lang-group">
  <div class="lang-tabs">
    <button class="lang-btn active" data-lang="ru">🇷🇺 Русский</button>
    <button class="lang-btn" data-lang="ua">🇺🇦 Українська</button>
    <button class="lang-btn" data-lang="pl">🇵🇱 Polski</button>
  </div>
  <slot />
</div>

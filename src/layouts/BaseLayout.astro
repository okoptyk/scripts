---
import '@/styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import { link } from '@/config/link';
import { navLabels, footerNote, titles } from '@/i18n/ui';

interface Props {
  slug: string;        // 'index' for home, else stage slug
  copy?: string;       // value for body[data-copy] — enables copy.js auto-buttons
                       // ('all' = whole page, or a CSS selector like '#tab-msg')
}
const { slug, copy } = Astro.props;

const titleSet = titles[slug];
const i18n = {
  nav: navLabels,
  footer: footerNote,
  titles: titleSet,
};
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{titleSet.ru}</title>
  <script is:inline set:html={`window.__I18N__=${JSON.stringify(i18n)};`}></script>
</head>
<body data-page={slug} data-copy={copy}>
  <Navbar active={slug} />
  <slot />
  <Footer />
  <script is:inline src={link('scripts/site-lang.js?v=2')}></script>
  <script is:inline src={link('scripts/ui.js?v=2')}></script>
  <script is:inline src={link('scripts/copy.js?v=2')}></script>
</body>
</html>
